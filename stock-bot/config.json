{
  "agents": {
    "defaults": {
      "workspace": "${NANOBOT_WORKSPACE}",
      "model": "deepseek-v4-flash",
      "provider": "deepseek",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 200,
      "maxConcurrentSubagents": 1,
      "maxToolResultChars": 16000,
      "providerRetryMode": "standard",
      "timezone": "Asia/Shanghai",
      "botName": "股市小助手",
      "botIcon": "📈",
      "unifiedSession": false,
      "disabledSkills": [],
      "idleCompactAfterMinutes": 0,
      "maxMessages": 120,
      "consolidationRatio": 0.5,
      "dream": {
        "intervalH": 2,
        "modelOverride": null,
        "maxBatchSize": 20,
        "maxIterations": 15,
        "annotateLineAges": true
      }
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "sendMaxRetries": 3,
    "websocket": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 8766,
      "path": "/",
      "token": "${NANOBOT_WS_TOKEN}",
      "tokenIssuePath": "",
      "tokenIssueSecret": "",
      "tokenTtlS": 300,
      "websocketRequiresToken": false,
      "allowFrom": ["*"],
      "streaming": true,
      "maxMessageBytes": 37748736,
      "pingIntervalS": 20.0,
      "pingTimeoutS": 20.0
    }
  },
  "providers": {
    "deepseek": {
      "apiKey": "${DEEPSEEK_API_KEY}",
      "apiBase": "https://api.deepseek.com/v1"
    }
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8901,
    "timeout": 120.0
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18791,
    "heartbeat": {
      "enabled": true,
      "intervalS": 1800,
      "keepRecentMessages": 8
    }
  },
  "tools": {
    "web": {
      "enable": true,
      "search": {
        "provider": "duckduckgo",
        "maxResults": 5,
        "timeout": 30
      },
      "fetch": {
        "useJinaReader": true
      }
    },
    "exec": {
      "enable": true,
      "timeout": 120,
      "allowedEnvKeys": ["MX_APIKEY", "NANOBOT_WORKSPACE"],
      "allowPatterns": [],
      "denyPatterns": []
    },
    "my": {
      "enable": true,
      "allowSet": false
    },
    "restrictToWorkspace": false
  }
}
